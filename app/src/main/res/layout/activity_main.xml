<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- CONTENUTO CENTRALE (Chat e Input) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_app">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/input_layout"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <!-- Barra di Input fluttuante -->
        <LinearLayout
            android:id="@+id/input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:background="@color/background_app"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:gravity="bottom">

            <EditText
                android:id="@+id/input_edit_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Chiedi qualcosa o incolla un link..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_bar"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:maxLines="4"
                android:elevation="2dp"
                android:inputType="textMultiLine|textCapSentences" />

            <ImageButton
                android:id="@+id/send_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_chat_user"
                android:elevation="2dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@android:color/white"
                android:contentDescription="Invia"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- TENDINA SINISTRA (Cronologia e Impostazioni) -->
    <LinearLayout
        android:id="@+id/nav_view_left"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@android:color/white">

        <Button
            android:id="@+id/btn_new_chat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="+ Nuova Analisi URL" />

        <Button
            android:id="@+id/btn_setup_termux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configura Termux"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btn_delete_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elimina Tutte le Sessioni"
            android:textColor="#EF4444"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:text="Riassunti Recenti"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/history_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Impostazioni"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>

    <!-- TENDINA DESTRA (Gerarchia File Playlist) -->
    <LinearLayout
        android:id="@+id/nav_view_right"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@android:color/white">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Esplora Playlist"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/files_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>